# ─── Django Configuration ─────────────────────────────────────────────────────
# Generate a new secret key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# Set to False in production
DJANGO_DEBUG=False

# Comma-separated list of allowed hosts (tu dominio de producción)
# Ejemplo: calculadora.petermanncapitalgroup.cl,www.petermanncapitalgroup.cl
DJANGO_ALLOWED_HOSTS=calculadora.petermanncapitalgroup.cl

# Comma-separated list of trusted origins for CSRF (include https://)
DJANGO_CSRF_TRUSTED_ORIGINS=https://calculadora.petermanncapitalgroup.cl

# Dominios autorizados a incrustar la calculadora en un <iframe> (CSP frame-ancestors).
# Separados por comas, con https://. Si no se define, usa los dominios de Petermann.
# DJANGO_FRAME_ANCESTORS=https://petermanncapitalgroup.cl,https://www.petermanncapitalgroup.cl

# Database URL — opcional. Si se define (ej. PostgreSQL), se usa en vez de SQLite.
# En cPanel/desarrollo puedes dejarlo vacío (usará SQLite: db.sqlite3).
DATABASE_URL=

# ─── Superusuario (seed.py) ───────────────────────────────────────────────────
# Si DJANGO_SUPERUSER_PASSWORD no está definida, seed.py NO crea superusuario
# (créalo con: python manage.py createsuperuser). Si el usuario ya existe,
# seed.py sincroniza su contraseña con esta variable.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=
DJANGO_SUPERUSER_EMAIL=admin@localhost

# ─── Media (imágenes subidas) ─────────────────────────────────────────────────
# En cPanel las imágenes se guardan en la carpeta media/ del proyecto (persistente).
# Solo define esto si quieres apuntar a otra ruta.
# DJANGO_MEDIA_ROOT=/home/USUARIO/calculadora-inmobiliaria/media
