# ─── Django Configuration ─────────────────────────────────────────────────────
# Generate a new secret key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# Set to False in production
DJANGO_DEBUG=False

# Comma-separated list of allowed hosts (your domain)
DJANGO_ALLOWED_HOSTS=tudominio.cl,www.tudominio.cl

# Comma-separated list of trusted origins for CSRF (include https://)
DJANGO_CSRF_TRUSTED_ORIGINS=https://tudominio.cl,https://www.tudominio.cl
