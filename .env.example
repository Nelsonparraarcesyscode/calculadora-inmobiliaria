# ─── Django Configuration ─────────────────────────────────────────────────────
# Generate a new secret key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# Set to False in production
DJANGO_DEBUG=False

# Comma-separated list of allowed hosts (your Railway domain + custom domain if applies)
# Example: myapp.up.railway.app,www.tudominio.cl
DJANGO_ALLOWED_HOSTS=myapp.up.railway.app

# Comma-separated list of trusted origins for CSRF (include https://)
DJANGO_CSRF_TRUSTED_ORIGINS=https://myapp.up.railway.app

# Database URL — Railway lo provee automáticamente al agregar PostgreSQL
# En desarrollo local puedes dejarlo vacío (usará SQLite)
DATABASE_URL=

# ─── Superusuario (seed.py) ───────────────────────────────────────────────────
# Si DJANGO_SUPERUSER_PASSWORD no está definida, seed.py NO crea superusuario
# (créalo con: python manage.py createsuperuser). Si el usuario ya existe,
# seed.py sincroniza su contraseña con esta variable.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=
DJANGO_SUPERUSER_EMAIL=admin@localhost

# ─── Media persistente (Railway) ──────────────────────────────────────────────
# Railway borra el filesystem en cada deploy. Monta un volumen (ej: /data)
# y apunta esta variable a él para que las imágenes subidas persistan.
# DJANGO_MEDIA_ROOT=/data/media
